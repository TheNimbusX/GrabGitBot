APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Для продакшена (Docker + Caddy): https://твой-домен (должен совпадать с APP_DOMAIN)
APP_DOMAIN=
# Часовой пояс для напоминаний fitbot:daily-reminder (08:00)
APP_TIMEZONE=Europe/Moscow

# Админка https://домен/admin — пароль для входа
FITBOT_ADMIN_PASSWORD=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# Локально: 127.0.0.1 | Docker Compose: mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
# Пароль root MySQL в Docker Compose (сервис mysql). Задай свой.
DB_ROOT_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# --- Исходящий прокси до api.telegram.org (РФ/KZ и др., где Bot API режется) ---
# Laravel/Guzzle (curl): один URL на всё исходящее к Telegram.
#
# HTTP-прокси (CONNECT к HTTPS):
#   TELEGRAM_HTTP_PROXY=http://HOST:PORT
#   TELEGRAM_HTTP_PROXY=http://USER:PASSWORD@HOST:PORT
#   Спецсимволы в логине/пароле — URL-encode (%40 вместо @ и т.д.)
#
# SOCKS5 (если на сервере поднят клиент v2ray/xray sing-box и слушает 1080):
#   TELEGRAM_HTTP_PROXY=socks5://127.0.0.1:1080
#
# Проверка с VPS (до правок в Laravel):
#   curl -m 20 -x http://USER:PASS@HOST:PORT https://api.telegram.org/bot<ТОКЕН>/getMe
#
# После изменения .env в Docker:
#   docker compose exec app php artisan config:clear && docker compose exec app php artisan config:cache
#   docker compose exec app php artisan telegram:test-api
TELEGRAM_HTTP_PROXY=

# Вебхук не нужен при docker compose up -d telegram-poll (long polling).

# Ежеминутный cron на хосте (напоминания в 08:00 по APP_TIMEZONE):
# * * * * * cd /path/to/GrabGitBot && docker compose exec -T app php artisan schedule:run >> /dev/null 2>&1

# Docker / cPanel: если 80 и 443 заняты Apache, раскомментируй и выставь Telegram webhook на https://домен:8443/...
CADDY_HTTP_PORT=8080
CADDY_HTTPS_PORT=8443
